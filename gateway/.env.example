# Which model backend to route to: anthropic (default) | openai | vllm
INFERENCE_BACKEND=anthropic

# Anthropic backend (default). The gateway holds this key now, not the app.
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# openai / vllm backends: forward to an OpenAI-compatible upstream.
# UPSTREAM_BASE_URL=https://api.openai.com/v1     # or the vLLM server URL
# UPSTREAM_API_KEY=sk-CHANGE_ME

# Per-key token-bucket rate limiting.
RATE_LIMIT_PER_MIN=120
RATE_LIMIT_BURST=20
