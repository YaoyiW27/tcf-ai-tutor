# Async PostgreSQL connection string (asyncpg driver).
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://tcf_app:CHANGE_ME@localhost:5432/tcf_ai_tutor

# Inference gateway base URL. Text-LLM calls (graders + examiner) route through
# the gateway, which holds the provider keys. Defaults to the local gateway.
GATEWAY_URL=http://localhost:8001

# Anthropic API key — now used by the gateway (gateway/.env), not the backend
# directly. Kept here for reference / local scripts.
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# OpenAI API key, used only for Whisper speech-to-text on the Speaking path
# (POST /speaking/answers). Optional: the app still boots without it and the
# Writing path is unaffected; the speaking upload endpoint returns 503 when unset.
OPENAI_API_KEY=sk-CHANGE_ME

# Langfuse (LLM observability / tracing for the grader). Get keys from a project
# at https://cloud.langfuse.com (or your self-hosted instance). Optional:
# tracing is disabled when these are unset and grading still works.
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
LANGFUSE_HOST=https://cloud.langfuse.com
