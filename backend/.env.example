# Async PostgreSQL connection string (asyncpg driver).
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://tcf_app:CHANGE_ME@localhost:5432/tcf_ai_tutor

# Anthropic API key for the AI grader (POST /answers/{id}/grade).
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Langfuse (LLM observability / tracing for the grader). Get keys from a project
# at https://cloud.langfuse.com (or your self-hosted instance). Optional:
# tracing is disabled when these are unset and grading still works.
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
LANGFUSE_HOST=https://cloud.langfuse.com
